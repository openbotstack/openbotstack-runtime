# OpenBotStack — Environment Configuration
# Copy to .env and edit values before starting.
#
# Static (deploy-time) config goes here. Runtime-mutable config
# (LLM providers, API keys, models) is managed via the Admin API
# at POST /v1/admin/providers — do NOT put provider credentials here.

# --- Required ---

# HTTP listen address
OBS_SERVER_ADDR=:8080

# JWT signing secret (≥32 chars; also seeds audit-chain + provider-key encryption)
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# --- Recommended ---

# Log level: debug | info | warn | error
OBS_LOG_LEVEL=info

# Allow vision/image tools to access private IPs (needed for internal image hosts).
# Set to true if your images are on 10.x, 172.16–31.x, or 192.168.x addresses.
OBS_VISION_ALLOW_PRIVATE_NETWORKS=false

# --- Optional ---

# SQLite database path (parent directory is auto-created)
# OBS_DATABASE_PATH=data/openbotstack.db

# Skills directory (auto-created on startup)
# OBS_SKILLS_PATH=data/skills

# AES-GCM key for encrypting provider API keys at rest. Falls back to JWT_SECRET.
# OBS_DB_ENCRYPTION_KEY=

# Comma-separated dirs allowed for read_file / write_file builtin tools
# OBS_FILE_ALLOWED_DIRS=/tmp,/data

# Agent execution mode: harness
# OBS_AGENT_MODE=harness
